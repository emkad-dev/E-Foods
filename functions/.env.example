# Runtime traffic through Supavisor connection pooling:
DATABASE_URL="postgresql://postgres.YOUR_SUPABASE_PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct migration traffic. Use the Session pooler port 5432 on machines that cannot reach the IPv6-only direct host:
DIRECT_URL="postgresql://postgres.YOUR_SUPABASE_PROJECT_REF:YOUR_URL_ENCODED_PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:5432/postgres"

# Pure direct connection template. Use this only if your environment supports IPv6 or your Supabase project has the IPv4 Add-On:
# DIRECT_URL="postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@db.YOUR_SUPABASE_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"

BOOTSTRAP_ADMIN_EMAILS="admin@example.com"

# Supabase auth / claims cutover runtime.
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_PROJECT_REF="YOUR_PROJECT_REF"
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Paystack phase-1 customer payments:
PAYSTACK_SECRET_KEY="sk_test_your_secret_key_here"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_CALLBACK_URL="https://your-web-app-or-confirmation-page.example.com/payment-return"
# Paystack dashboard webhook URL:
# https://YOUR_PROJECT_REF.supabase.co/functions/v1/paystack-webhook

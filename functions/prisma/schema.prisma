generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AppRole {
  customer
  restaurant
  dispatch
  admin
  support
}

enum RestaurantApprovalStatus {
  pending
  approved
  unpublished
}

model UserAccount {
  uid                    String               @id
  email                  String
  displayName            String?
  phoneNumber            String?
  photoURL               String?
  emailVerified          Boolean              @default(false)
  roleDisplay            AppRole?
  partnerApplicationStatus String?
  partnerApplicationReviewedAt DateTime?
  partnerApplicationRejectionReason String?
  dispatchApplicationStatus String?
  dispatchApplicationReviewedAt DateTime?
  dispatchApplicationRejectionReason String?
  expoPushToken          String?
  pushTokenUpdatedAt     DateTime?
  activeSessionId        String?
  activeSessionUpdatedAt DateTime?
  accountDisabled        Boolean              @default(false)
  disabledAt             DateTime?
  disabledByUid          String?
  lastPrivilegedRole     AppRole?
  restaurantId           String?
  restaurantName         String?
  restaurantLinkedAt     DateTime?
  restaurantLinkSource   String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @default(now()) @updatedAt
  roles                  UserRole[]
  assignedRoles          UserRole[]           @relation("RoleAssignedBy")
  ownedRestaurants       RestaurantRecord[]   @relation("RestaurantOwner")
  approvedRestaurants    RestaurantApproval[] @relation("ApprovalActor")
  approvedPartnerApplications PartnerApplicationRecord[] @relation("PartnerApplicationReviewer")
  approvedDispatchApplications DispatchApplicationRecord[] @relation("DispatchApplicationReviewer")
  auditLogs              AdminAuditLog[]      @relation("AuditActor")
  favoriteRestaurants    CustomerFavoriteRestaurant[]
  policyAcceptances      UserPolicyAcceptance[]
}

model UserRole {
  id           String      @id @default(cuid())
  userId       String
  role         AppRole
  restaurantId String?
  assignedByUid String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @default(now()) @updatedAt
  user         UserAccount @relation(fields: [userId], references: [uid], onDelete: Cascade)
  assignedBy   UserAccount? @relation("RoleAssignedBy", fields: [assignedByUid], references: [uid], onDelete: SetNull)

  @@unique([userId, role])
  @@index([role])
  @@index([restaurantId])
}

model RestaurantRecord {
  id               String              @id
  ownerId          String?
  name             String
  nameKey          String?
  cuisine          String?
  address          String?
  description      String?
  image            String?
  logoImage        String?
  menu             Json?
  deliveryFee      Float?
  deliveryRadiusKm Float?
  deliveryTime     String?
  openingTime      String?
  closingTime      String?
  latitude         Float?
  longitude        Float?
  minOrder         Float?
  paystackSubaccountCode String?
  supportsDelivery Boolean             @default(true)
  supportsPickup   Boolean             @default(true)
  isOpen           Boolean             @default(true)
  isPublished      Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  owner            UserAccount?        @relation("RestaurantOwner", fields: [ownerId], references: [uid], onDelete: SetNull)
  approval         RestaurantApproval?
  orders           CustomerOrder[]
  favorites        CustomerFavoriteRestaurant[]
}

model RestaurantApproval {
  id            String                   @id @default(cuid())
  restaurantId  String                   @unique
  status        RestaurantApprovalStatus @default(pending)
  approvedByUid String?
  approvedAt    DateTime?
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  restaurant    RestaurantRecord         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  approvedBy    UserAccount?             @relation("ApprovalActor", fields: [approvedByUid], references: [uid], onDelete: SetNull)

  @@index([status])
}

model PartnerApplicationRecord {
  id              String       @id
  uid             String       @unique
  email           String
  contactName     String
  phoneNumber     String
  restaurantName  String
  cuisine         String
  address         String
  description     String?
  logoImage       String?
  latitude        Float?
  longitude       Float?
  deliveryTime    String?
  status          String
  restaurantId    String?
  submittedAt     DateTime
  reviewedAt      DateTime?
  approvedByUid   String?
  rejectionReason String?
  updatedAt       DateTime     @updatedAt
  approvedBy      UserAccount? @relation("PartnerApplicationReviewer", fields: [approvedByUid], references: [uid], onDelete: SetNull)

  @@index([status])
  @@index([submittedAt])
}

model CustomerFavoriteRestaurant {
  id           String           @id @default(cuid())
  customerId   String
  restaurantId String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  customer     UserAccount      @relation(fields: [customerId], references: [uid], onDelete: Cascade)
  restaurant   RestaurantRecord @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([customerId, restaurantId])
  @@index([customerId])
  @@index([restaurantId])
}

model UserPolicyAcceptance {
  id             String      @id @default(cuid())
  userId         String
  email          String
  app            String
  termsVersion   String
  privacyVersion String
  source         String
  acceptedAt     DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  user           UserAccount @relation(fields: [userId], references: [uid], onDelete: Cascade)

  @@unique([userId, app, termsVersion, privacyVersion])
  @@index([userId])
  @@index([app])
  @@index([acceptedAt])
}

model DispatchApplicationRecord {
  id              String       @id
  uid             String       @unique
  email           String
  displayName     String
  phoneNumber     String
  region          String
  lga             String
  vehicleType     String
  currentAddress  String?
  latitude        Float?
  longitude       Float?
  status          String
  submittedAt     DateTime
  reviewedAt      DateTime?
  approvedByUid   String?
  rejectionReason String?
  updatedAt       DateTime     @updatedAt
  approvedBy      UserAccount? @relation("DispatchApplicationReviewer", fields: [approvedByUid], references: [uid], onDelete: SetNull)

  @@index([status])
  @@index([submittedAt])
}

model CustomerOrder {
  id               String             @id
  customerId       String
  restaurantId     String
  restaurantName   String
  status           String
  fulfillmentType  String
  pricing          Json
  payment          Json
  deliveryAddress  String?
  deliveryLocation Json?
  cancellation     Json?
  attributedPromoId String?
  timeline         Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  restaurant       RestaurantRecord   @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  items            OrderItem[]
  assignment       DeliveryAssignment?
  deliveryEvents   DeliveryEvent[]
  paymentTransactions PaymentTransaction[]

  @@index([customerId])
  @@index([restaurantId])
  @@index([status])
  @@index([attributedPromoId])
}

model PaymentTransaction {
  id                   String        @id @default(cuid())
  orderId              String
  customerId           String
  restaurantId         String
  provider             String
  method               String
  reference            String        @unique
  currency             String
  amount               Float
  status               String
  accessCode           String?
  authorizationUrl     String?
  externalTransactionId String?
  channel              String?
  gatewayStatus        String?
  lastError            String?
  paidAt               DateTime?
  failedAt             DateTime?
  verifiedAt           DateTime?
  splitSubaccountCode  String?
  initializeResponse   Json?
  verificationResponse Json?
  webhookEvent         Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  order                CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([customerId])
  @@index([restaurantId])
  @@index([status])
}

model OrderItem {
  id             Int           @id @default(autoincrement())
  orderId        String
  itemId         String
  name           String
  price          Float
  quantity       Int
  restaurantId   String
  restaurantName String
  order          CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model DeliveryAssignment {
  orderId         String        @id
  dispatchId      String?
  dispatchOwnerId String?
  courierId       String?
  courierName     String?
  assignedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  order           CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([dispatchId])
  @@index([dispatchOwnerId])
  @@index([courierId])
}

model DispatchRiderRecord {
  id             String   @id
  displayName    String
  status         String
  zone           String
  region         String?
  lga            String?
  phoneNumber    String?
  currentAddress String?
  vehicleType    String
  acceptanceRate Float?
  activeLoad     Int      @default(0)
  completedTrips Int      @default(0)
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
  @@index([zone])
}

model DeliveryEvent {
  id        String        @id @default(cuid())
  orderId    String
  eventType String
  actorUid  String?
  note      String?
  details   Json?
  createdAt DateTime      @default(now())
  order     CustomerOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([eventType])
  @@index([actorUid])
}

model IdempotencyRecord {
  key       String   @id
  scope     String
  actorUid  String
  response  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([actorUid, scope])
}

model AdminAuditLog {
  id         String       @id @default(cuid())
  actorUid   String?
  action     String
  targetType String
  targetId   String?
  details    Json?
  createdAt  DateTime     @default(now())
  actor      UserAccount? @relation("AuditActor", fields: [actorUid], references: [uid], onDelete: SetNull)

  @@index([actorUid])
  @@index([action])
  @@index([targetType])
}

enum QueueJobType {
  order_placement
  payment_verification
  notifications
}

enum QueueJobStatus {
  pending
  processing
  completed
  failed
  cancelled
}

model QueueJob {
  id            String            @id @default(cuid())
  type          QueueJobType
  status        QueueJobStatus    @default(pending)
  payload       Json
  result        Json?
  error         String?
  retryCount    Int               @default(0)
  maxRetries    Int               @default(3)
  nextRetryAt   DateTime?
  processedAt   DateTime?
  failedAt      DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([nextRetryAt])
}

model OrderPlacementJob {
  id            String        @id @default(cuid())
  queueJobId    String        @unique
  orderId       String        @unique
  customerId    String
  restaurantId  String
  items         Json
  status        String        @default("pending")
  notificationSent Boolean    @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([status])
}

model PaymentVerificationJob {
  id            String        @id @default(cuid())
  queueJobId    String        @unique
  orderId       String        @unique
  paymentReference String
  status        String        @default("pending")
  verificationResult Json?
  failureReason String?
  retriedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
}

model NotificationJob {
  id            String        @id @default(cuid())
  queueJobId    String        @unique
  recipients    Json
  payload       Json
  status        String        @default("pending")
  sentCount     Int           @default(0)
  failedCount   Int           @default(0)
  details       Json?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

model SupportConversation {
  id            String           @id @default(cuid())
  customerId    String           @unique
  subject       String?
  status        String           @default("open") // open | pending | closed
  assignedTo    String?
  channel       String           @default("in_app")
  lastMessageAt DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  messages      SupportMessage[]

  @@index([status])
  @@index([assignedTo])
  @@index([lastMessageAt])
}

model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  senderType     String // customer | agent | system
  senderId       String?
  body           String
  emailSent      Boolean             @default(false)
  pushSent       Boolean             @default(false)
  createdAt      DateTime            @default(now())
  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Broadcast {
  id             String    @id @default(cuid())
  title          String
  category       String // marketing | transactional
  channels       Json // ["email","push"]
  segment        Json
  emailSubject   String?
  emailBody      String?
  pushTitle      String?
  pushBody       String?
  status         String    @default("draft") // draft|scheduled|sending|sent|failed|canceled
  scheduledAt    DateTime?
  recipientCount Int       @default(0)
  sentEmail      Int       @default(0)
  failedEmail    Int       @default(0)
  sentPush       Int       @default(0)
  failedPush     Int       @default(0)
  createdByUid   String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sentAt         DateTime?

  @@index([status])
  @@index([scheduledAt])
  @@index([createdAt])
}

model EmailSuppression {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String // unsubscribe | bounce | complaint
  createdAt DateTime @default(now())

  @@index([reason])
}

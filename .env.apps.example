# Shared Expo app runtime flags.
# Copy this file to `.env.apps` at the repo root when you want one setting to apply to all four apps.

EXPO_PUBLIC_DEV_AUTH_BYPASS=false
EXPO_PUBLIC_DEV_AUTH_EMAIL=dev@example.com
EXPO_PUBLIC_DEV_AUTH_UID=dev-user

# Shared Supabase auth runtime for all four apps.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLISHABLE_OR_ANON_KEY
EXPO_PUBLIC_SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
EXPO_PUBLIC_BACKEND_RPC_URL=
EXPO_PUBLIC_FUNCTIONS_REGION=us-central1

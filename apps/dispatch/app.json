{
  "expo": {
    "name": "FEASTY Dispatch",
    "slug": "feasty-dispatch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../customer/assets/images/icon.png",
    "scheme": "feasty-dispatch",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ebuy.dispatch",
      "associatedDomains": ["applinks:feasty.com"]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF3D4",
        "foregroundImage": "../customer/assets/images/android-icon-foreground.png",
        "backgroundImage": "../customer/assets/images/android-icon-background.png",
        "monochromeImage": "../customer/assets/images/android-icon-monochrome.png"
      },
      "package": "com.ebuy.dispatch",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "https", "host": "feasty.com" },
            { "scheme": "feasty-dispatch" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "../customer/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow FEASTY Dispatch to use your location for live delivery tracking."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "../customer/assets/images/android-icon-monochrome.png",
          "color": "#E4A11B"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "../customer/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "EXPO_PUBLIC_APP_DOMAIN": "feasty.com",
      "EXPO_PUBLIC_APP_SCHEME": "feasty-dispatch",
      "EXPO_PUBLIC_VERIFY_EMAIL_PATH": "verify-email",
      "EXPO_PUBLIC_RESET_PASSWORD_PATH": "reset-password"
    }
  }
}

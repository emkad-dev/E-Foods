{
  "expo": {
    "name": "FEASTY Customer",
    "slug": "ebuy-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ebuy-customer",
    "userInterfaceStyle": "automatic",
    "owner": "ghosty_xx",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ebuy.customer",
      "associatedDomains": ["applinks:ebuy.com"]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ebuy.customer",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            { "scheme": "https", "host": "ebuy.com" },
            { "scheme": "ebuy-customer" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": { "backgroundColor": "#000000" }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#f5b342"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dcd9458a-36cb-4f88-bd22-b53a99e1332b"
      },
      "EXPO_PUBLIC_PROJECT_ID": "G-VM017RKW5Q",
      "EXPO_PUBLIC_APP_DOMAIN": "ebuy.com",
      "EXPO_PUBLIC_APP_SCHEME": "ebuy-customer",
      "EXPO_PUBLIC_VERIFY_EMAIL_PATH": "verify-email",
      "EXPO_PUBLIC_RESET_PASSWORD_PATH": "reset-password",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "309665605080-vfjg90ffdc8sbtot6t4bgkti1c5ldd8i.apps.googleusercontent.com"
    }
  }
}

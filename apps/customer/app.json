{
  "expo": {
    "name": "FEASTY Customer",
    "slug": "E-Foods",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "feasty-customer",
    "userInterfaceStyle": "automatic",
    "owner": "ghosty_xx",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ebuy.customer",
      "associatedDomains": [
        "applinks:feasty.com"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFF6E8",
        "foregroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ebuy.customer",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "https",
              "host": "feasty.com"
            },
            {
              "scheme": "feasty-customer"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow FEASTY to use your location to find nearby restaurants."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#f5b342"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "autolinkingModuleResolution": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "dcd9458a-36cb-4f88-bd22-b53a99e1332b"
      },
      "EXPO_PUBLIC_PROJECT_ID": "G-VM017RKW5Q",
      "EXPO_PUBLIC_APP_DOMAIN": "feasty.com",
      "EXPO_PUBLIC_APP_SCHEME": "feasty-customer",
      "EXPO_PUBLIC_VERIFY_EMAIL_PATH": "verify-email",
      "EXPO_PUBLIC_RESET_PASSWORD_PATH": "reset-password",
      "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "309665605080-vfjg90ffdc8sbtot6t4bgkti1c5ldd8i.apps.googleusercontent.com"
    }
  }
}

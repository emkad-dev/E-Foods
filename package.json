{
  "name": "feasty-platform",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:admin": "npm --prefix apps/admin-web run dev",
    "dev:customer": "npm --prefix apps/customer run start",
    "dev:partner": "npm --prefix apps/partner run start",
    "dev:dispatch": "npm --prefix apps/dispatch run start",
    "build:admin": "npm --prefix apps/admin-web run build",
    "build:partner": "npm --prefix apps/partner run build:web",
    "typecheck:partner": "npm --prefix apps/partner run typecheck",
    "android:customer": "npm --prefix apps/customer run android",
    "android:partner": "npm --prefix apps/partner run android",
    "android:dispatch": "npm --prefix apps/dispatch run android",
    "lint:customer": "npm --prefix apps/customer run lint",
    "lint:partner": "npm --prefix apps/partner run lint",
    "lint:dispatch": "npm --prefix apps/dispatch run lint",
    "load:test": "node ./scripts/load-test-backend.mjs",
    "db:doctor": "npm --prefix functions run db:doctor",
    "db:generate": "npm --prefix functions run prisma:generate",
    "db:migrate:deploy": "npm --prefix functions run prisma:migrate:deploy",
    "db:validate": "npm --prefix functions run prisma:validate",
    "deploy:paystack": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy-paystack-functions.ps1",
    "deploy:functions": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\deploy-realtime-email-functions.ps1"
  },
  "dependencies": {
    "@sentry/browser": "^10.62.0",
    "@supabase/supabase-js": "^2.105.4",
    "jose": "^6.2.3",
    "jwt-decode": "^4.0.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "^13.16.1"
  },
  "devDependencies": {
    "@supabase/cli-windows-x64": "^2.101.0",
    "supabase": "^2.101.0"
  }
}
